---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Desarrollo de Software a la Medida",
    description:
      "Creamos aplicaciones web y de escritorio diseñadas específicamente para los procesos de tu empresa, con tecnologías modernas y escalables.",
    icon: "bx:bxs-terminal",
  },
  {
    title: "ERP con ERPNext",
    description:
      "Implementamos y personalizamos ERPNext para gestionar finanzas, inventario, compras, ventas, recursos humanos y más desde una sola plataforma.",
    icon: "bx:bxs-buildings",
  },
  {
    title: "Punto de Venta con ERPNext",
    description:
      "Soluciones de punto de venta basadas en ERPNext integradas con tu inventario y contabilidad en tiempo real para negocios de cualquier tamaño.",
    icon: "bx:bxs-store",
  },
  {
    title: "Infraestructura en la Nube con DigitalOcean",
    description:
      "Como partner oficial de DigitalOcean, diseñamos, desplegamos y gestionamos tu infraestructura en la nube: servidores, bases de datos, redes y Kubernetes con alto rendimiento y costos predecibles.",
    icon: "bx:bxs-cloud",
  },
  {
    title: "Business Intelligence y Analítica",
    description:
      "Transformamos tus datos en decisiones estratégicas con implementaciones de Power BI, Metabase y Google Looker Studio, conectados a tus fuentes de datos para dashboards en tiempo real.",
    icon: "bx:bxs-bar-chart-alt-2",
  },
  {
    title: "Consultoría Tecnológica",
    description:
      "Te acompañamos en la toma de decisiones tecnológicas, análisis de procesos y diseño de arquitecturas de software que impulsan el crecimiento de tu empresa.",
    icon: "bx:bxs-user-voice",
  },
  {
    title: "Integraciones y APIs",
    description:
      "Conectamos tus sistemas existentes con plataformas de terceros, servicios en la nube y herramientas externas mediante integraciones robustas y seguras.",
    icon: "bx:bxs-network-chart",
  },
  {
    title: "Soporte y Mantenimiento",
    description:
      "Ofrecemos soporte continuo, actualizaciones y mantenimiento preventivo para garantizar la disponibilidad y rendimiento óptimo de tus sistemas.",
    icon: "bx:bxs-wrench",
  },
];
---

<div class="mt-16 md:mt-0" id="servicios">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Nuestros Servicios
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Ofrecemos soluciones tecnológicas integrales para digitalizar y optimizar los procesos de tu empresa.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full  p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
