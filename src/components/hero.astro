---
import { Picture } from "astro:assets";
import heroImage from "@/assets/undraw_product-demo_9d4i.svg";
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <Picture
      src={heroImage}
      alt="Demostración de producto"
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      Soluciones de Software a la Medida
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      En Cuatrocubos desarrollamos software personalizado, implementamos sistemas ERP y punto de venta con ERPNext, y ofrecemos consultoría e integraciones para impulsar la transformación digital de tu empresa.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="#servicios"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-white w-5 h-5" name="bx:bxs-rocket" />
        Nuestros Servicios
      </Link>
      <Link
        size="lg"
        style="outline"
        href="/contacto"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-black w-4 h-4" name="bx:bxs-envelope" />
        Contáctanos
      </Link>
    </div>
  </div>
</main>
